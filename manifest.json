{
  "manifest_version": 3,
  "name": "PushChrome",
  "version": "1.0.0",
  "description": "Unofficial Pushover Browser Extension - view, send, and receive messages directly from your browser.",

  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "contextMenus",
    "offscreen",
    "clipboardWrite"
  ],

  "host_permissions": [
    "https://api.pushover.net/*"
  ],

  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },

  "action": {
    "default_popup": "src/pages/root.html",
    "default_icon": {
      "16": "src/icons/icon-16.png",
      "48": "src/icons/icon-48.png",
      "128": "src/icons/icon-128.png"
    }
  },

  "options_ui": {
    "page": "src/pages/settings.html",
    "open_in_tab": false
  },

  "icons": {
    "16": "src/icons/icon-16.png",
    "48": "src/icons/icon-48.png",
    "128": "src/icons/icon-128.png"
  }
}
